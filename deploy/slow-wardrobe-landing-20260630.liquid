<style>
:root{--paper:#FBF2F0;--warm:#FDF8F5;--ink:#3a3330;--soft:#6b615c;--rose:#9E4C58;--rose-deep:#7c3a45;--muted:#a8948e;--hair:rgba(158,76,88,.22)}
*{box-sizing:border-box}
body{margin:0;background:var(--paper);color:var(--ink);font-family:'EB Garamond',Georgia,serif;font-size:19px;line-height:1.7;-webkit-font-smoothing:antialiased}
img{display:block;max-width:100%}
a{color:var(--rose)}
.eyebrow{text-transform:uppercase;letter-spacing:.3em;font-size:.66rem;color:var(--rose);font-weight:500;margin:0 0 1.1rem}
.shell{display:grid;min-height:100vh}
@media(min-width:900px){.shell{grid-template-columns:1.05fr 1fr}}
.photo{position:relative;background:#2c2420;min-height:42vh}
.photo img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.photo::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,12,10,.05),rgba(20,12,10,.35))}
.photo .mk{position:absolute;top:22px;left:24px;z-index:2;color:#fff;font-family:'Cormorant Garamond',serif;letter-spacing:.34em;font-size:.85rem;text-transform:uppercase;text-decoration:none;padding:6px 8px;margin:-6px -8px}
.panel{display:flex;align-items:center;padding:clamp(2.4rem,6vw,4.5rem) clamp(1.6rem,5vw,3.6rem)}
.inner{width:100%;max-width:460px;margin:0 auto}
h1{font-family:'Cormorant Garamond',serif;font-weight:500;line-height:1.02;font-size:clamp(2.6rem,6vw,3.5rem);margin:0}
h1 .it{font-style:italic;color:var(--rose);display:block}
.sub{color:var(--soft);font-size:1.1rem;margin:1.1rem 0 0}
.list{list-style:none;padding:0;margin:1.8rem 0 0}
.list li{position:relative;padding:.5rem 0 .5rem 1.7rem;color:var(--soft);font-size:1rem;line-height:1.5}
.list li::before{content:"";position:absolute;left:0;top:.95rem;width:9px;height:9px;border:1.5px solid var(--rose);border-radius:50%}
form{margin:2.1rem 0 0}
label{display:block;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin:0 0 .5rem}
.row{display:flex;flex-direction:column;gap:.7rem}
input[type=email]{font-family:'EB Garamond',serif;font-size:1.05rem;padding:.95rem 1rem;border:1px solid var(--hair);
  background:#fff;color:var(--ink);border-radius:2px;width:100%}
input[type=email]:focus{outline:2px solid var(--rose);outline-offset:1px;border-color:transparent}
button{font-family:'EB Garamond',serif;font-size:.82rem;letter-spacing:.18em;text-transform:uppercase;
  background:var(--rose);color:#fff;border:0;padding:1rem 1.4rem;border-radius:2px;cursor:pointer;transition:background .25s}
button:hover{background:var(--rose-deep)}
.fine{font-size:.82rem;color:var(--muted);margin:1rem 0 0;font-style:italic}
.trust{margin:2.4rem 0 0;padding:1.8rem 0 0;border-top:1px solid var(--hair);color:var(--soft);font-size:1rem}
.trust .by{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin:.8rem 0 0}
.success{display:none}
.success.show{display:block;animation:fade .8s ease}
.success h1{font-size:clamp(2.2rem,5vw,3rem)}
.success .btns{display:flex;flex-wrap:wrap;gap:.8rem;margin:1.8rem 0 0}
.success .btns a{font-family:'EB Garamond',serif;font-size:.8rem;letter-spacing:.16em;text-transform:uppercase;
  padding:.9rem 1.5rem;border-radius:2px;text-decoration:none}
.btn-primary{background:var(--rose);color:#fff}
.btn-ghost{background:transparent;color:var(--rose);border:1px solid var(--hair)}
@keyframes fade{from{opacity:0;transform:translateY(10px)}to{opacity:1}}
@media(prefers-reduced-motion:reduce){.success.show{animation:none}}
@media(max-width:899px){.photo{min-height:30vh}.panel{padding-top:1.4rem;padding-bottom:2.4rem}.sub{margin-top:.8rem}.list{margin-top:1.1rem}.list li{padding-top:.4rem;padding-bottom:.4rem}form{margin-top:1.4rem}.trust{margin-top:1.8rem;padding-top:1.4rem}}
</style></head><body>
<div class="shell">
  <div class="photo"><a class="mk" href="/">Me&nbsp;+&nbsp;Lia</a><img src="https://cdn.shopify.com/s/files/1/0746/9708/1059/files/slow-wardrobe-img-01.jpg?v=1781248212&width=1600" alt="A Me + Lia floral cotton dress with a leather bag and sunglasses"></div>
  <div class="panel"><div class="inner">

    <div id="capture">
      <p class="eyebrow">A free guide from Me + Lia</p>
      <h1>Build a Wardrobe You <span class="it">Actually Want to Open.</span></h1>
      <p class="sub">The Slow Wardrobe — ten pages on owning less and loving it more, from the founders of Me + Lia. Sent straight to your inbox.</p>
      <ul class="list">
        <li>The quiet questions to ask before anything joins your wardrobe.</li>
        <li>How to read fabric like you've done it for years — weight, weave, and the squeeze test.</li>
        <li>A simple way to build a wardrobe that lasts, one considered piece at a time.</li>
      </ul>
      <form id="signup" novalidate>
        <label for="email">Where should we send it?</label>
        <div class="row">
          <input type="email" id="email" name="email" placeholder="you@email.com" required autocomplete="email">
          <button type="submit">Send me the guide</button>
        </div>
        <p class="fine">Thoughtful emails only, direct from us at the studio. Unsubscribe anytime.</p>
      </form>

      <div class="trust">
        <p>We made this because we got tired of clothes that disappoint — beautiful in the photo, thin and forgettable in your hands. This is everything we've learned about choosing pieces that last, and what we think about when we make them.</p>
        <p class="by">— Melina &amp; Meilia, Me + Lia</p>
      </div>
    </div>

    <div class="success" id="done">
      <p class="eyebrow">It's on its way</p>
      <h1>Check your inbox — <span class="it">and here it is now.</span></h1>
      <p class="sub">We've sent a copy to your email so you can keep it. You can also start reading right here.</p>
      <div class="btns">
        <a class="btn-primary" href="/pages/slow-wardrobe">Read the guide</a>
        <a class="btn-ghost" href="https://cdn.shopify.com/s/files/1/0746/9708/1059/files/The_Slow_Wardrobe_-_Me_Lia.pdf?v=1781144120" target="_blank" rel="noopener" download>Download the PDF</a>
      </div>
    </div>

  </div></div>
</div>
<script>
(function(){
  var KLAVIYO_PUBLIC_KEY  = "TzKtNp";
  var LEAD_MAGNET_LIST_ID = "W3NE8n";
  var form = document.getElementById('signup');
  var btn  = form.querySelector('button[type=submit]');
  var em   = document.getElementById('email');

  // --- Source / UTM capture -------------------------------------------------
  // Reads utm_* from the URL on first landing, persists for the session, and
  // attaches them (plus a derived channel) to the Klaviyo profile on submit.
  var UTM_KEYS = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
  function readUtmsFromUrl(){
    var params = new URLSearchParams(window.location.search);
    var out = {};
    UTM_KEYS.forEach(function(k){ var v = params.get(k); if(v){ out[k] = v; } });
    return out;
  }
  function persistFirstTouch(){
    try{
      var fromUrl = readUtmsFromUrl();
      if(Object.keys(fromUrl).length && !sessionStorage.getItem('ml_utms')){
        sessionStorage.setItem('ml_utms', JSON.stringify(fromUrl));
        sessionStorage.setItem('ml_landing', window.location.href);
      }
    }catch(e){}
  }
  function getUtms(){
    var fromUrl = readUtmsFromUrl();
    if(Object.keys(fromUrl).length){ return fromUrl; }
    try{ var raw = sessionStorage.getItem('ml_utms'); return raw ? JSON.parse(raw) : {}; }
    catch(e){ return {}; }
  }
  function deriveChannel(src){
    if(!src){ return 'Direct'; }
    var s = String(src).toLowerCase();
    if(s==='facebook'||s==='instagram'||s==='fb'||s==='ig'||s==='meta'){ return 'Meta'; }
    if(s==='pinterest'||s==='pin'){ return 'Pinterest'; }
    if(s==='google'){ return 'Google'; }
    return src;
  }
  persistFirstTouch();
  // -------------------------------------------------------------------------

  function reveal(){
    document.getElementById('capture').style.display='none';
    document.getElementById('done').classList.add('show');
    window.scrollTo({top:0,behavior:'smooth'});
  }
  form.addEventListener('submit', function(e){
    e.preventDefault();
    if(!em.value || !/.+@.+\..+/.test(em.value)){ em.focus(); em.style.borderColor='var(--rose)'; return; }
    btn.disabled = true; btn.textContent = 'Sending\u2026';

    var utms = getUtms();
    var props = { lead_magnet:'The Slow Wardrobe' };
    UTM_KEYS.forEach(function(k){ if(utms[k]){ props[k] = utms[k]; } });
    props.channel = deriveChannel(utms.utm_source);
    try{ var lp = sessionStorage.getItem('ml_landing'); if(lp){ props.landing_url = lp; } }catch(e){}

    fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'revision':'2025-01-15' },
      body: JSON.stringify({
        data:{
          type:'subscription',
          attributes:{
            profile:{ data:{ type:'profile', attributes:{
              email: em.value,
              properties: props
            } } }
          },
          relationships:{ list:{ data:{ type:'list', id: LEAD_MAGNET_LIST_ID } } }
        }
      })
    }).then(function(){
      if(window.fbq){ fbq('track','Lead',{content_name:'The Slow Wardrobe',content_category:'Lead Magnet'}); }
      if(window.pintrk){ try{ pintrk('set',{em: em.value}); }catch(e){} pintrk('track','lead',{lead_type:'Slow Wardrobe Guide'}); }
      reveal();
    }).catch(reveal);
  });
})();
</script>
</body></html>