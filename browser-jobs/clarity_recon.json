{
  "type": "browser",
  "filename": "clarity_recon",
  "headful": true,
  "width": 1440,
  "height": 900,
  "steps": [
    {
      "do": "goto",
      "url": "https://clarity.microsoft.com/projects/view/wdwgfvbixn/impressions",
      "waitUntil": "domcontentloaded",
      "timeoutMs": 60000
    },
    {
      "do": "waitMs",
      "ms": 90000
    },
    {
      "do": "screenshot",
      "name": "clarity_recon",
      "fullPage": true
    },
    {
      "do": "eval",
      "as": "recon",
      "script": "()=>{const q=s=>[...document.querySelectorAll(s)];const txt=e=>((e&&e.textContent)||'').trim().slice(0,120);const login={hasMsLogin:!!document.querySelector('input[name=loginfmt],#i0116,form[name=f1]'),signInText:/sign in|log in|microsoft account/i.test(document.body.innerText.slice(0,2000))};const navLinks=q('a[href]').map(a=>({t:txt(a),href:a.getAttribute('href')})).filter(x=>x.t&&/record|dashboard|heatmap|setting|impression|session/i.test(x.t)).slice(0,25);const cardSel='[class*=card],[class*=session],[class*=recording],[data-testid]';const cards=q(cardSel).slice(0,3).map(e=>({cls:String(e.className).slice(0,200),testid:e.getAttribute('data-testid'),html:e.outerHTML.slice(0,1500)}));return{url:location.href,title:document.title,login,navLinks,cardCount:q(cardSel).length,cards};}"
    }
  ]
}