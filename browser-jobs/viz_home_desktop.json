{
  "type": "browser",
  "filename": "viz_home_desktop",
  "headful": false,
  "width": 1440,
  "height": 900,
  "steps": [
    {
      "do": "goto",
      "url": "https://meandlia.com/",
      "waitUntil": "domcontentloaded",
      "timeoutMs": 60000
    },
    {
      "do": "waitMs",
      "ms": 3500
    },
    {
      "do": "scroll",
      "passes": 20,
      "pauseMs": 360
    },
    {
      "do": "waitMs",
      "ms": 1400
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,0); return document.body.scrollHeight; }",
      "as": "pageHeight"
    },
    {
      "do": "waitMs",
      "ms": 700
    },
    {
      "do": "screenshot",
      "name": "full",
      "fullPage": true
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,0); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v00",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,1500); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v01",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,3000); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v02",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,4500); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v03",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,6000); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v04",
      "fullPage": false
    }
  ]
}