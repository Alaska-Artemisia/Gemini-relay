{
  "type": "browser",
  "filename": "test_slowwardrobe",
  "headful": false,
  "steps": [
    {
      "do": "goto",
      "url": "https://meandlia.com/slow-wardrobe",
      "waitUntil": "load",
      "timeoutMs": 30000
    },
    {
      "do": "waitFor",
      "selector": "h1",
      "timeoutMs": 15000
    },
    {
      "do": "text",
      "selector": "h1",
      "as": "headline"
    },
    {
      "do": "eval",
      "script": "() => document.title",
      "as": "pageTitle"
    },
    {
      "do": "count",
      "selector": "a",
      "as": "linkCount"
    },
    {
      "do": "exists",
      "selector": "a[href$='.pdf']",
      "as": "hasPdfLink"
    },
    {
      "do": "eval",
      "script": "() => { const a=[...document.querySelectorAll('a')].find(x=>/download|guide|pdf/i.test((x.textContent||'')+' '+(x.href||''))); return a ? a.href : null; }",
      "as": "guideHref"
    },
    {
      "do": "screenshot",
      "name": "page",
      "fullPage": true
    }
  ]
}