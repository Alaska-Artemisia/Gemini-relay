{
  "type": "browser",
  "filename": "viz_home_mobile",
  "headful": false,
  "width": 390,
  "height": 844,
  "deviceScaleFactor": 3,
  "userAgent": "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Mobile/15E148 Safari/604.1",
  "steps": [
    {
      "do": "goto",
      "url": "https://meandlia.com/",
      "waitUntil": "domcontentloaded",
      "timeoutMs": 60000
    },
    {
      "do": "waitMs",
      "ms": 3500
    },
    {
      "do": "scroll",
      "passes": 20,
      "pauseMs": 360
    },
    {
      "do": "waitMs",
      "ms": 1400
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,0); return document.body.scrollHeight; }",
      "as": "pageHeight"
    },
    {
      "do": "waitMs",
      "ms": 700
    },
    {
      "do": "screenshot",
      "name": "full",
      "fullPage": true
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,0); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v00",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,1400); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v01",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,2800); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v02",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,4200); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v03",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,5600); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v04",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,7000); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v05",
      "fullPage": false
    },
    {
      "do": "eval",
      "script": "() => { window.scrollTo(0,8400); return window.scrollY; }"
    },
    {
      "do": "waitMs",
      "ms": 550
    },
    {
      "do": "screenshot",
      "name": "v06",
      "fullPage": false
    }
  ]
}