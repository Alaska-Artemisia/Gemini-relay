{
  "type": "browser",
  "filename": "clarity_recon3",
  "headful": true,
  "width": 1440,
  "height": 900,
  "steps": [
    {
      "do": "goto",
      "url": "https://clarity.microsoft.com/projects",
      "waitUntil": "domcontentloaded",
      "timeoutMs": 60000
    },
    {
      "do": "waitMs",
      "ms": 8000
    },
    {
      "do": "click",
      "selector": "text=Me + Lia"
    },
    {
      "do": "waitMs",
      "ms": 9000
    },
    {
      "do": "click",
      "selector": "text=Recordings"
    },
    {
      "do": "waitMs",
      "ms": 12000
    },
    {
      "do": "screenshot",
      "name": "clarity_recordings",
      "fullPage": true
    },
    {
      "do": "eval",
      "as": "rec",
      "script": "()=>{const q=s=>[...document.querySelectorAll(s)];const clip=e=>(e.outerHTML||'').slice(0,1400);const testids=[...new Set(q('[data-testid]').map(e=>e.getAttribute('data-testid')).filter(Boolean))].slice(0,40);const sel='[class*=session],[class*=recording],[class*=Session],[class*=Recording],[class*=card],[class*=Card]';const cards=q(sel).slice(0,4).map(e=>({cls:String(e.className).slice(0,160),testid:e.getAttribute('data-testid'),html:clip(e)}));const recNav=q('a,button').filter(e=>/record/i.test(e.textContent||'')).map(e=>({t:(e.textContent||'').trim().slice(0,30),href:e.getAttribute('href')})).slice(0,6);return{url:location.href,title:document.title,testids,cardCount:q(sel).length,cards,recNav};}"
    }
  ]
}